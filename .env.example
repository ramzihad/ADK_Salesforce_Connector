# Environment variables for ADK Salesforce Connector

# Basic Authentication (username/password)
SF_USERNAME=your-salesforce-username
SF_PASSWORD=your-salesforce-password
SF_SECURITY_TOKEN=your-security-token-if-required

# Connection Settings
SF_LOGIN_URL=https://login.salesforce.com
SF_API_VERSION=59.0
SF_SANDBOX=false

# OAuth Settings (alternative to username/password)
SF_CLIENT_ID=your-oauth-consumer-key
SF_CLIENT_SECRET=your-oauth-consumer-secret
SF_REDIRECT_URI=https://your-app.com/oauth/callback